{
  "name": "petvault-vue",
  "version": "1.0.0",
  "description": "PetLog – CRUD de mascotas con Vue 3",
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --coverageReporters=cobertura --reporters=default --reporters=jest-junit"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": ["petlog.js"],
    "coverageThreshold": {
      "global": {
        "lines":     80,
        "functions": 80,
        "branches":  70,
        "statements":80
      }
    }
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0"
  }
}
